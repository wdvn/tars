# LLM — default local Ollama (qwen2.5:0.5b, matches src/llm/config.zig)
TARS_LLM_MODEL=qwen2.5:0.5b
TARS_LLM_AUTO_PULL=1
OLLAMA_HOST=http://127.0.0.1:11434
# Alternative small model: TARS_LLM_MODEL=deepseek-r1:0.5b

# Cloud backends (require explicit provider or URL)
# OPENAI_COMPAT_URL=https://api.openai.com/v1
# OPENAI_COMPAT_API_KEY=sk-...
# OPENAI_COMPAT_MODEL=gpt-4o-mini
# OPENAI_COMPAT_API_HEADER=Authorization

# Legacy OpenAI aliases (use with TARS_LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (use TARS_LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Force provider: ollama | openai | anthropic | claude | stub
# TARS_LLM_PROVIDER=ollama

# Runtime
# TARS_MAX_TOKENS=8192
# TARS_SYSTEM_FILE=./prompts/tars.md
# TARS_STREAM_FORMAT=plain|sse|ndjson
# Chat memory controller (P1 — see docs/vi/problem-solving.md)
# TARS_SESSION_RAW_TURNS=6
# TARS_SESSION_POOL=24
# TARS_SESSION_RECALL_K=3
# TARS_EPISODIC_RECALL_K=2
# TARS_CONTEXT_MAX_CHARS=24000

# Embedding (Qwen3-Embedding via Ollama — defaults match src/memory/embed/config.zig)
TARS_EMBED_PROVIDER=ollama
TARS_EMBED_MODEL=qwen3-embedding:0.6b
TARS_EMBED_DIM=512
TARS_EMBED_AUTO_PULL=1
TARS_EMBED_INSTRUCTION=Given a TARS mission goal and agent run context, retrieve relevant episodic memories from past missions.
TARS_EMBED_MAX_CHARS=8192
