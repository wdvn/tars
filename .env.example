# LLM backends (mini-agent compatible)
# Priority: OPENAI_COMPAT_* → ANTHROPIC_API_KEY → OLLAMA_HOST

# OpenAI / OpenRouter / LM Studio / vLLM
# OPENAI_COMPAT_URL=https://api.openai.com/v1
# OPENAI_COMPAT_API_KEY=sk-...
# OPENAI_COMPAT_MODEL=gpt-4o-mini
# OPENAI_COMPAT_API_HEADER=Authorization

# Legacy aliases (still supported)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama (local fallback)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3

# Force provider: openai | anthropic | claude | ollama | stub
# TARS_LLM_PROVIDER=openai

# Runtime
# TARS_MAX_TOKENS=8192
# TARS_SYSTEM_FILE=./prompts/tars.md
# TARS_STREAM_FORMAT=plain|sse|ndjson

# Embedding (Qwen3-Embedding via Ollama — replaces hash when enabled)
# TARS_EMBED_PROVIDER=hash|ollama|auto
# TARS_EMBED_PROVIDER=ollama
# TARS_EMBED_MODEL=qwen3-embedding:0.6b
# TARS_EMBED_DIM=512
# TARS_EMBED_AUTO_PULL=1
# TARS_EMBED_INSTRUCTION=Given a TARS mission goal and agent run context, retrieve relevant episodic memories from past missions.
# TARS_EMBED_MAX_CHARS=8192
# OLLAMA_HOST=http://127.0.0.1:11434
